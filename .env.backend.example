# MongoDB Connection
DATABASE_URL=mongodb://sirret_user:your_password@mongodb-host:27017/sirret_prod

# Security
SECRET_KEY=your-secret-key-here-min-32-characters-long

# CORS
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Application
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
