# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# Application
PROJECT_NAME=Sistema Regional de Registros de Transporte (SIRRET)
VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database MongoDB
MONGODB_URL=mongodb://admin:password@localhost:27017/
DATABASE_NAME=drtc_db

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:3000,http://127.0.0.1:3000

# URLs
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:8000/api/v1

# System Information
SISTEMA_NOMBRE=SIRRET
SISTEMA_NOMBRE_COMPLETO=Sistema Regional de Registros de Transporte (SIRRET)
ENTIDAD_NOMBRE=Dirección Regional de Transportes y Comunicaciones Puno
DOMINIO_INSTITUCIONAL=transportespuno.gob.pe
EMAIL_INSTITUCIONAL=admin@transportespuno.gob.pe

# External APIs
RENIEC_API_URL=https://api.reniec.gob.pe
SUNARP_API_URL=https://api.sunarp.gob.pe

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# QR Configuration
QR_SIZE=10
QR_BORDER=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/sirret.log

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Session
SESSION_TIMEOUT_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
