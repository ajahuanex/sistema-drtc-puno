# Frontend Environment Configuration
# Copy this file to .env.local and update values for your environment

# API Configuration
ANGULAR_APP_API_URL=http://localhost:8000/api/v1
ANGULAR_APP_BASE_URL=http://localhost:8000
ANGULAR_APP_FRONTEND_URL=http://localhost:4200

# System Information
ANGULAR_APP_SYSTEM_NAME=SIRRET
ANGULAR_APP_SYSTEM_FULL_NAME=Sistema Regional de Registros de Transporte (SIRRET)
ANGULAR_APP_ENTITY_NAME=Dirección Regional de Transportes y Comunicaciones Puno
ANGULAR_APP_VERSION=1.0.0

# Feature Flags
ANGULAR_APP_USE_DATA_MANAGER=false
ANGULAR_APP_ENABLE_ANALYTICS=false
ANGULAR_APP_ENABLE_DEBUG=false

# External Services (Future)
ANGULAR_APP_CONDUCTORES_EXTERNO_URL=
ANGULAR_APP_CONDUCTORES_EXTERNO_ENABLED=false
